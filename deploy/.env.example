# 功能描述：环境变量模板，复制为 .env 并填写实际值后使用
#           cp .env.example .env
# ============================================================

# ── 数据库 ────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=blogdb
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── 认证 ──────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── 对外访问地址（替换为实际域名或 IP）────────────────────────
# 博客前台 Nuxt SSR 服务端渲染时使用
NUXT_PUBLIC_API_URL=http://your-domain.com/api/v1

# 管理后台 config.js 注入的 API 地址
API_URL=http://your-domain.com/api/v1

# 强制指定 scheme（https/http），留空则自动从请求头检测
# Docker 部署且外部有 HTTPS 反代时建议设置为 https
SERVER_SCHEME=