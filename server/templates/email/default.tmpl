<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body { 
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; 
  line-height: 1.6; 
  color: #333; 
  background-color: #f5f5f5; 
  margin: 0; 
  padding: 20px; 
}
.container { 
  max-width: 600px; 
  margin: 0 auto; 
  background-color: #ffffff; 
  padding: 30px; 
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
.header {
  margin-bottom: 20px;
}
.header h1 {
  color: #4a90e2;
  font-size: 24px;
  margin: 0 0 10px 0;
}
.content h2 {
  color: #4a90e2;
  font-size: 18px;
  margin: 0 0 15px 0;
}
.quote { 
  background-color: #f8f9fa; 
  border-left: 4px solid #4a90e2; 
  padding: 15px; 
  margin: 15px 0; 
  border-radius: 4px;
}
.quote p { 
  margin: 5px 0; 
  color: #333; 
}
.button { 
  display: inline-block; 
  background-color: #4a90e2; 
  color: #ffffff !important; 
  padding: 12px 28px; 
  text-decoration: none; 
  border-radius: 6px; 
  margin: 20px 0 10px 0;
  font-weight: 500;
}
.footer { 
  margin-top: 30px; 
  padding-top: 20px; 
  border-top: 1px solid #eee; 
  text-align: center; 
  color: #999; 
  font-size: 13px; 
}
.footer a { 
  color: #4a90e2; 
  text-decoration: none; 
}
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <h1>📢 {{.Title}}</h1>
  </div>
  <div class="content">
    <h2>通知</h2>
    <div class="quote">
      <p>{{.Content}}</p>
    </div>
    <a href="{{.SiteURL}}{{.Link}}" class="button">查看详情</a>
  </div>
  <div class="footer">
    <p>此邮件由 {{.SiteName}} 自动发送，请勿直接回复。</p>
    <p><a href="{{.SiteURL}}">访问网站</a></p>
  </div>
</div>
</body>
</html>
